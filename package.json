{
  "name": "discord-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && ..\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
    "dev:backend:lan": "cd backend && ..\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:frontend:lan": "npm --prefix frontend run dev:lan",
    "dev:frontend:lan:https": "npm --prefix frontend run dev:lan:https",
    "docker:up": "docker compose up --build",
    "docker:up:https": "docker compose -f compose.yaml -f compose.https.yaml up --build",
    "docker:up:https:detached": "docker compose -f compose.yaml -f compose.https.yaml up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check:voice:readiness": "node scripts/voice_readiness_check.mjs",
    "smoke:realtime:browser": "node scripts/realtime_browser_smoke.mjs",
    "smoke:realtime:redis": ".\\.venv\\Scripts\\python.exe scripts\\realtime_redis_smoke.py",
    "lint:backend": "cd backend && ..\\.venv\\Scripts\\python -m ruff check app tests",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "cd backend && ..\\.venv\\Scripts\\python -m pytest"
  }
}
