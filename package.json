{
  "name": "discord-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend && ..\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --port 8000",
    "dev:backend:lan": "cd backend && ..\\.venv\\Scripts\\python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:frontend:lan": "npm --prefix frontend run dev:lan",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "lint:backend": "cd backend && ..\\.venv\\Scripts\\python -m ruff check app tests",
    "lint:frontend": "npm --prefix frontend run lint",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "cd backend && ..\\.venv\\Scripts\\python -m pytest"
  }
}
