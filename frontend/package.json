{
  "name": "discord-clone-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host 0.0.0.0",
    "dev:lan:https": "node scripts/ensureHttpsCertEnv.mjs && vite --host 0.0.0.0",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "oxlint .",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-vue-next": "^0.555.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.3",
    "oxlint": "^1.64.0",
    "playwright": "^1.61.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.1.8"
  }
}
