# Copy this file to .env and fill in local values.

ENVIRONMENT=local
JWT_SECRET=replace-with-a-long-random-local-secret
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Neon PostgreSQL. Leave empty for local UI/backend shell mode.
DATABASE_URL=

# Upstash Redis. Leave empty until realtime fan-out is wired.
REDIS_URL=

# Frontend can call the Vite proxy by default, so this is optional.
VITE_API_BASE_URL=
