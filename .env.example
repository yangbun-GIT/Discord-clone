# Copy this file to .env and fill in local values.

ENVIRONMENT=local
JWT_SECRET=replace-with-a-long-random-local-secret-32-bytes-min
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Neon PostgreSQL. Leave empty for native local fallback mode.
# Docker Compose supplies a local PostgreSQL URL automatically.
DATABASE_URL=

# Upstash Redis. Leave empty until realtime fan-out is wired.
REDIS_URL=

# Frontend can call the Vite proxy by default, so this is optional.
VITE_API_BASE_URL=
