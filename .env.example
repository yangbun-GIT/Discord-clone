# Copy this file to .env and fill in local values.

ENVIRONMENT=local
JWT_SECRET=replace-with-a-long-random-local-secret-32-bytes-min
# Add http://<host-ip>:5173 when testing from another device on the same LAN.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional local HTTPS LAN development certificate files for Vite.
# Use trusted local development certificates only. Do not commit key material.
# For Docker HTTPS LAN, generate certs/lan-dev.pfx with
# scripts/create_lan_https_cert.ps1, then use compose.https.yaml.
VITE_HTTPS_PFX_FILE=
VITE_HTTPS_PFX_PASSPHRASE=
VITE_HTTPS_KEY_FILE=
VITE_HTTPS_CERT_FILE=

# Production/deployment domain. Keep this blank for local development.
# Example: APP_DOMAIN=discord-clone.example.com
APP_DOMAIN=
ACME_EMAIL=

# Neon/PostgreSQL. Leave empty for native local fallback mode.
# Docker Compose supplies a local PostgreSQL URL automatically.
DATABASE_URL=

# Redis. Leave empty for native single-process development.
REDIS_URL=

# WebRTC ICE servers as JSON. Replace with Open Relay / Metered Video TURN servers
# when testing voice across NATs or deployed networks.
WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"}]
# Example with TURN:
# WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"replace-me","credential":"replace-me"}]

# Self-hosted coturn values should live only in the host secret store or a
# non-committed deployment .env. Do not commit generated TURN secrets.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=discord_clone

# Frontend can call the Vite proxy by default, so this is optional.
VITE_API_BASE_URL=
