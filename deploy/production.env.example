# Copy this file to deploy/production.env on the deployment host.
# Fill deploy/production.env with real values on the host only.
# Do not commit deploy/production.env or any real secret value.

APP_DOMAIN=discord-clone.example.com
ACME_EMAIL=admin@example.com

POSTGRES_USER=discord_clone
POSTGRES_PASSWORD=replace-with-host-secret
POSTGRES_DB=discord_clone

JWT_SECRET=replace-with-long-random-host-secret-32-bytes-min
CORS_ORIGINS=https://discord-clone.example.com

# External voice is not complete unless this includes at least one real turn: or
# turns: server and the readiness check reports turn_configured=true.
WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"replace-with-turn-username","credential":"replace-with-turn-credential"}]
